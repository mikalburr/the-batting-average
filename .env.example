DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/the_batting_average?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/the_batting_average?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin credentials
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="your-strong-password"

# ── AI Scoring (required for batch scoring pipeline) ──
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# ── Tier 2 API keys (optional — enrichment works without these) ──
# Discogs: discogs.com → Settings → Developers → Generate Token
DISCOGS_USER_TOKEN=""

# Spotify (optional — iTunes handles images for free, Discogs handles credits)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
