DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/the_batting_average?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin credentials
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="your-strong-password"

# ── Tier 2 API keys (optional — enrichment works without these, just less data) ──
# Spotify: developer.spotify.com → your app → Client ID + Secret
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Discogs: discogs.com → Settings → Developers → Generate Token
DISCOGS_USER_TOKEN=""
